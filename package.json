{
  "name": "agent-arena",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:api": "turbo dev --filter=@agent-arena/api",
    "dev:mobile": "turbo dev --filter=@agent-arena/mobile"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2"
  }
}
