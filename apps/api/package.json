{
  "name": "@agent-arena/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file=../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run --env-file=../../.env src/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/openai": "^3.0.47",
    "@coral-xyz/anchor": "^0.32.1",
    "@hono/trpc-server": "^0.3.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@privy-io/server-auth": "^1.32.5",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@trpc/server": "^11.0.0",
    "ai": "^6.0.134",
    "bs58": "^6.0.0",
    "bullmq": "^5.10.0",
    "drizzle-orm": "^0.33.0",
    "exa-js": "^2.10.2",
    "hono": "^4.5.0",
    "ioredis": "^5.4.0",
    "nanoid": "^5.0.0",
    "openai": "^4.50.0",
    "postgres": "^3.4.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
