// AgentArena Environment Variables

// Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

// Redis (Upstash)
REDIS_URL=redis://default:[password]@[region].upstash.io:6379

// Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
// NO private keys — we use Privy for all signing

// Execute trades? devnet=false (decision-only), mainnet=true
EXECUTE_TRADES=false

// Test mode (set true to simulate wallet/balance for testing without real blockchain)
TEST_MODE=false
TEST_WALLET_BALANCE_USDC=1000
TEST_WALLET_BALANCE_SOL=0

// Jupiter Predict API
JUPITER_API_KEY=your_jupiter_api_key_here

// OpenRouter LLM (Qwen 3.6 Plus Free — FREE model)
OPENROUTER_API_KEY=your_openrouter_api_key_here

// Exa AI Web Search (FREE tier available)
EXA_API_KEY=your_exa_api_key_here

// Kimi LLM (Moonshot AI) — optional fallback
// KIMI_API_KEY=your_kimi_api_key_here
// KIMI_BASE_URL=https://api.moonshot.ai/v1

// OpenAI (GPT-4o, GPT-4o-mini) — optional fallback
// OPENAI_API_KEY=your_openai_key_here

// Anthropic (Claude) — optional fallback
// ANTHROPIC_API_KEY=your_anthropic_key_here

// Model overrides (optional — defaults to qwen analysis + qwen decisions)
// AGENT_MODEL_ANALYSIS=qwen
// AGENT_MODEL_DECISION=qwen

// Privy (Wallet Management — server-side agent wallets, NO user private keys)
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

// Helius RPC
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

// Geo Data APIs (All FREE)
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
ACLED_API_URL=https://acleddata.com/api/acled/read
ACLED_EMAIL=your_email@example.com
ACLED_KEY=your_acled_key_here
FRED_API_KEY=your_fred_api_key_here
NASA_FIRMS_MAP_KEY=your_nasa_firms_key_here

// Twitter/X API (optional — for social signals)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

// Platform
PLATFORM_FEE_BPS=200
PLATFORM_TREASURY=your_solana_wallet_address_here

// Alerting (optional — webhook URL for critical errors)
ALERT_WEBHOOK_URL=

// App
PORT=3001
WS_PORT=3002
NODE_ENV=development
